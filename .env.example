# Supabase pooled connection string for the app at runtime.
# For serverless deployments, use Supavisor transaction mode and add pgbouncer=true.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct or session-mode connection string for Prisma CLI commands and migrations.
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Secret used to sign SMS verification cookies.
SMS_VERIFICATION_SECRET="replace-with-a-long-random-secret"

# Semaphore SMS credentials for OTP verification and rental notifications.
SEMAPHORE_API_KEY="replace-with-your-semaphore-api-key"
SEMAPHORE_SENDERNAME="YourApprovedSenderName"

# Lightweight admin access gate.
ADMIN_PASSWORD="replace-with-your-admin-password"
ADMIN_AUTH_SECRET="replace-with-a-long-random-secret"
